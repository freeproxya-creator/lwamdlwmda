local function collectHopCandidates()
    local current = tostring(game.JobId)
    local fresh, rejoin, seen = {}, {}, {}
    local cursor = nil

    for _ = 1, 15 do
        local page = fetchPublicServerPage(cursor)
        if not page or type(page.data) ~= "table" then break end

        for _, s in page.data do
            local id = tostring(s.id or "")
            if id == "" or id == current or seen[id] then continue end
            local playing = tonumber(s.playing) or 0
            local maxPlayers = tonumber(s.maxPlayers) or 50
            if playing >= maxPlayers then continue end
            seen[id] = true

            if isFreshServer(id) then
                fresh[#fresh + 1] = id
            else
                local age = getVisitedAge(id)
                if age and age >= VISITED_REJOIN_AFTER then
                    rejoin[#rejoin + 1] = { id = id, age = age }
                end
            end
        end

        local nextCursor = page.nextPageCursor
        if type(nextCursor) ~= "string" or nextCursor == "" or (#fresh + #rejoin) >= 40 then break end
        cursor = nextCursor
    end

    if #fresh > 0 then
        for i = #fresh, 2, -1 do
            local j = math.random(1, i)
            fresh[i], fresh[j] = fresh[j], fresh[i]
        end
        return fresh
    end

    if #rejoin > 0 then
        table.sort(rejoin, function(a, b) return a.age > b.age end)
        local out = {}
        for _, entry in ipairs(rejoin) do
            out[#out + 1] = entry.id
        end
        for i = #out, 2, -1 do
            local j = math.random(1, i)
            out[i], out[j] = out[j], out[i]
        end
        return out
    end

    return {}
end

local function hopToRandomServer()
    if shouldBlockHop() then return false end
    hoppingBusy = true
    saveConfig()
    local ok = xpcall(function()
        markVisited(game.JobId)

        local candidates = collectHopCandidates()
        if #candidates == 0 then return end

        local pick = candidates[1]
        local startJob = tostring(game.JobId)
        Services.TeleportService:TeleportToPlaceInstance(game.PlaceId, pick, LocalPlayer)

        task.spawn(function()
            for _ = 1, 20 do
                task.wait(0.5)
                local nowJob = tostring(game.JobId)
                if nowJob ~= startJob then
                    markVisited(nowJob)
                    break
                end
            end
        end)
    end, noopErr)
    task.delay(3, function() hoppingBusy = false end)
    return ok
end

local function joinServerByJobId(jobId)
    jobId = tostring(jobId or ""):gsub("%s+", "")
    if jobId == "" then
        notify("Join Server", "Enter a job id first")
        return
    end
    inputJobId = jobId
    saveConfig()
    xpcall(function()
        Services.TeleportService:TeleportToPlaceInstance(game.PlaceId, jobId, LocalPlayer)
    end, noopErr)
end

local function scanAndBuyCycle()
    initMapFolders()
    local pets = collectAllPets()
    updateHopLockFromPets(pets)
    for _, entry in ipairs(pets) do
        sendScanSpawnWebhook(entry)
        task.wait(0.15)
    end
    local targets = {}
    for _, entry in ipairs(pets) do
        if entry.tameable and matchesAnySelectedPet(entry.species, entry.size) then
            targets[#targets + 1] = entry
        end
    end
    if #targets == 0 then
        hopLockedForPet = false
        return false, nil, "no target"
    end
    hopLockedForPet = true
    table.sort(targets, function(a, b) return (a.price or 0) < (b.price or 0) end)
    local pick = targets[1]
    local targetLabel = pick.displayName
    local bought = attemptBuyPet(pick)
    sendAutoBuyWebhook(targetLabel, true, bought and "success" or "fail")
    saveConfig()
    return true, pick, bought and "success" or "fail"
end

local function cacheScriptSourceForAutoExec()
    if type(genv.__NTMT_HOP_SOURCE) == "string" and #genv.__NTMT_HOP_SOURCE > 200 then return end
    if not (readfile and isfile) then return end
    for _, path in EXEC_SOURCE_PATHS do
        if isfile(path) then
            local ok, src = xpcall(readfile, noopErr, path)
            if ok and type(src) == "string" and #src > 200 then
                genv.__NTMT_HOP_SOURCE = src
                return
            end
        end
    end
end

local function buildAutoExecutePayload()
    local url = scriptUrl
    if (not url or url == "") and type(genv.NTMT_HOP_SCRIPT_URL) == "string" then
        url = genv.NTMT_HOP_SCRIPT_URL
    end
    if type(url) == "string" and url ~= "" then
        return string.format([[
task.defer(function()
    getgenv().__NTMT_HOP_SERVER_RUNNING = nil
    local ok, src = pcall(function() return game:HttpGet(%q) end)
    if ok and type(src) == "string" then loadstring(src, "NTMT_HOP")() end
end)
]], url)
    end
    if type(genv.__NTMT_HOP_SOURCE) == "string" and #genv.__NTMT_HOP_SOURCE > 200 then
        genv.__NTMT_HOP_SOURCE_B64 = genv.__NTMT_HOP_SOURCE
        return [[
task.defer(function()
    getgenv().__NTMT_HOP_SERVER_RUNNING = nil
    local s = getgenv().__NTMT_HOP_SOURCE_B64 or getgenv().__NTMT_HOP_SOURCE
    if type(s) == "string" then loadstring(s, "NTMT_HOP")() end
end)
]]
    end
    if readfile and isfile then
        for _, path in EXEC_SOURCE_PATHS do
            if isfile(path) then
                return string.format([[
task.defer(function()
    getgenv().__NTMT_HOP_SERVER_RUNNING = nil
    if readfile and isfile(%q) then loadstring(readfile(%q), "NTMT_HOP")() end
end)
]], path, path)
            end
        end
    end
    return nil
end

local function setupAutoExecute()
    local queueFn = (syn and syn.queue_on_teleport) or queue_on_teleport or (fluxus and fluxus.queue_on_teleport)
    if type(queueFn) ~= "function" then return false end
    cacheScriptSourceForAutoExec()
    local payload = buildAutoExecutePayload()
    if not payload then return false end
    LocalPlayer.OnTeleport:Connect(function(state)
        if genv.AutoExecute ~= true then return end
        if autoExecuteQueued then return end
        if state == Enum.TeleportState.Started or state == Enum.TeleportState.InProgress then
            autoExecuteQueued = true
            saveConfig()
            syncConfigToGenv()
            xpcall(function() queueFn(buildAutoExecutePayload() or payload) end, noopErr)
        end
    end)
    return true
end

