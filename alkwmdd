function resolveRefFromModel(model)
    if not model or not WildPetFolder then return nil end
    local refName = string.match(model.Name, "^WildPet_.-_(.+)$")
    local ref = refName and WildPetFolder:FindFirstChild(refName)
    if ref and ref:IsA("BasePart") then return ref end
    for _, ch in WildPetFolder:GetChildren() do
        if ch:IsA("BasePart") and model.Name:find(ch.Name, 1, true) then return ch end
    end
    return nil
end

function isRefTameable(refPart)
    if not refPart or not refPart:IsA("BasePart") or not refPart.Parent then return false end
    local ownerId = refPart:GetAttribute("OwnerUserId")
    if ownerId == LocalPlayer.UserId then return false end
    if type(ownerId) == "number" and ownerId ~= 0 then return false end
    local price = refPart:GetAttribute("Price")
    if type(price) == "number" and getSheckles() < price then return false end
    return true
end

function tryBuyPet()
    if not genv.ftgs_AutoBuyPet or not WildPetSpawns or isCatchingPet then return end
    if os.clock() - lastPet < COOLDOWN.Pet then return end
    initMapFolders()
    if not WildPetFolder then return end
    local candidates = {}
    for _, model in WildPetSpawns:GetChildren() do
        if not model:IsA("Model") then continue end
        if not matchesAnySelectedPet(model:GetAttribute("PetName"), model:GetAttribute("PetSize")) then continue end
        local ref = resolveRefFromModel(model)
        if not ref or not isRefTameable(ref) then continue end
        local root = model.PrimaryPart or model:FindFirstChild("RootPart") or model:FindFirstChildWhichIsA("BasePart")
        local price = ref:GetAttribute("Price") or 0
        candidates[#candidates + 1] = { ref = ref, root = root, model = model, price = price, species = model:GetAttribute("PetName") }
    end
    if #candidates == 0 then return end
    table.sort(candidates, function(a, b) return (a.price or 0) < (b.price or 0) end)
    local pick = candidates[1]
    local key = tostring(pick.ref)
    if petCatchCooldown[key] and os.clock() - petCatchCooldown[key] < COOLDOWN.Pet then return end
    petCatchCooldown[key] = os.clock()
    lastPet = os.clock()
    isCatchingPet = true
    task.spawn(function()
        local tpPart = pick.root or pick.ref
        local tpPos = tpPart and tpPart.Position
        local prompt = (pick.model and pick.model:FindFirstChildWhichIsA("ProximityPrompt", true))
            or (pick.ref and pick.ref:FindFirstChildWhichIsA("ProximityPrompt", true))
        local tameRemote = Net.Pets and Net.Pets.WildPetTame
        local function doTame()
            if prompt then fireProximityPrompt(prompt) end
            if tameRemote then safeNetCall(tameRemote, pick.ref) end
        end
        movementBypass = true
        if tpPos then tpInstant(tpPos) end
        task.wait(0.03)
        doTame()
        local done, conn = false, nil
        local tr = Net.Pets and Net.Pets.WildPetTameResult
        if tr and tr.OnClientEvent then
            conn = tr.OnClientEvent:Connect(function(_, uid) if uid == LocalPlayer.UserId then done = true end end)
        end
        local deadline = os.clock() + 2.5
        while not done and os.clock() < deadline do
            if tpPos then
                local hrp = getRoot()
                if hrp then
                    hrp.AssemblyLinearVelocity = Vector3.zero
                    hrp.AssemblyAngularVelocity = Vector3.zero
                    hrp.CFrame = CFrame.new(tpPos + Vector3.new(0, 3, 0))
                end
            end
            doTame()
            task.wait(0.08)
        end
        if conn then conn:Disconnect() end
        if done then trackPetBuy(getPetDisplayName(pick.species, nil), pick.price) end
        movementBypass = false
        isCatchingPet = false
    end)
end

