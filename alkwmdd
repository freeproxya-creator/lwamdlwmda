local function collectAllPets()
    initMapFolders()
    local seen, out = {}, {}
    local function push(ref, model, species, size)
        if not ref or not species then return end
        local key = ref:GetFullName()
        if seen[key] then return end
        seen[key] = true
        out[#out + 1] = {
            ref = ref,
            model = model,
            species = species,
            size = size,
            displayName = getPetDisplayName(species, size),
            rarity = getPetRarity(species),
            price = ref:GetAttribute("Price") or (model and model:GetAttribute("Price")) or 0,
            pos = getWildPetPosition({ ref = ref, model = model, root = model and model.PrimaryPart }),
            tameable = isRefTameable(ref),
        }
    end
    if WildPetFolder then
        for _, ref in WildPetFolder:GetChildren() do
            if ref:IsA("BasePart") and ref.Parent then
                push(ref, nil, ref:GetAttribute("PetName"), ref:GetAttribute("PetSize"))
            end
        end
    end
    if WildPetSpawns then
        for _, model in WildPetSpawns:GetChildren() do
            if model:IsA("Model") then
                local ref = resolveRefFromModel(model)
                push(ref, model, model:GetAttribute("PetName"), model:GetAttribute("PetSize"))
            end
        end
    end
    return out
end

local function attemptBuyPet(pick)
    if not pick or not pick.ref or not pick.tameable then return false end
    buyingBusy = true
    local tameRemote = Net and Net.Pets and Net.Pets.WildPetTame
    local success = false
    xpcall(function()
        if pick.pos then tpInstant(pick.pos) end
        for _ = 1, 28 do
            if tameRemote then safeNetCall(tameRemote, pick.ref) end
            task.wait(0.01)
        end
        local prompt = pick.ref:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            for _ = 1, 6 do fireProximityPromptFast(prompt) end
        end
        task.wait(0.25)
        success = pick.ref:GetAttribute("OwnerUserId") == LocalPlayer.UserId
    end, noopErr)
    buyingBusy = false
    return success
end

