local function formatCompactNumber(amount)
    amount = math.floor(tonumber(amount) or 0)
    if amount >= 1000000000 then
        local v = math.floor(amount / 1000000000 * 10 + 0.5) / 10
        return (v == math.floor(v) and string.format("%db", math.floor(v)) or string.format("%gb", v))
    end
    if amount >= 1000000 then
        local v = math.floor(amount / 1000000 * 10 + 0.5) / 10
        return (v == math.floor(v) and string.format("%dm", math.floor(v)) or string.format("%gm", v))
    end
    if amount >= 1000 then
        local v = math.floor(amount / 1000 * 10 + 0.5) / 10
        return (v == math.floor(v) and string.format("%dk", math.floor(v)) or string.format("%gk", v))
    end
    return tostring(amount)
end

