local function patchWindUISource(body)
    if type(body) ~= "string" then return body, false end
    local replacement = "local d=b({Icons={}})"
    local exact = 'local d=b(game:GetService"ReplicatedStorage":WaitForChild("GetIcons",99999):InvokeServer())'
    local s, e = body:find(exact, 1, true)
    if s then
        body = body:sub(1, s - 1) .. replacement .. body:sub(e + 1)
    end
    body = body:gsub(
        'b%(game%.GetService%("ReplicatedStorage"%)%:WaitForChild%("GetIcons",%d+%):InvokeServer%(%)%)',
        'b({Icons={}})'
    )
    body = body:gsub(
        'b%(game:GetService"ReplicatedStorage":WaitForChild%("GetIcons",%d+%):InvokeServer%(%)%)',
        'b({Icons={}})'
    )
    body = body:gsub(
        'game%.GetService%("ReplicatedStorage"%)%:WaitForChild%("GetIcons"[^)]*%)%:InvokeServer%(%)',
        '{Icons={}}'
    )
    body = body:gsub(
        'game:GetService"ReplicatedStorage":WaitForChild%("GetIcons",%d+%):InvokeServer%(%)',
        '{Icons={}}'
    )
    body = body:gsub(':WaitForChild%("GetIcons"[^)]*%)%:InvokeServer%(%)', '{Icons={}}')
    local stillBad = body:find('GetIcons.-InvokeServer%(%)') ~= nil
    return body, not stillBad
end

local function buildWindUIEnv()
    local env = {}
    for k, v in pairs(_G) do env[k] = v end
    for k, v in pairs(genv) do env[k] = v end
    env.game = game
    env.workspace = workspace
    env.script = env.script or script
    env.getgenv = getgenv or function() return genv end
    env._G = genv
    return setmetatable(env, {
        __index = function(t, k)
            local v = rawget(t, k)
            if v ~= nil then return v end
            v = genv[k]
            if v ~= nil then return v end
            return _G[k]
        end,
    })
end

local function compileWindUIChunk(body)
    local env = buildWindUIEnv()
    if type(load) == "function" then
        local chunk, err = load(body, "WindUI", "t", env)
        if type(chunk) == "function" then return chunk end
        if err then return nil, err end
    end
    if type(loadstring) == "function" then
        local chunk, err = loadstring(body, "WindUI")
        if type(chunk) ~= "function" then return nil, err end
        if setfenv then
            pcall(function() setfenv(chunk, env) end)
        end
        return chunk
    end
    return nil, "no loadstring/load"
end

