function tryCollectMutationSeedsOnce()
    if not genv.ftgs_AutoCollectMutation or collectingMutation or not SeedPackSpawns then return end
    collectingMutation = true
    task.spawn(function()
        initMapFolders()
        for _, spawn in SeedPackSpawns:GetChildren() do
            if not genv.ftgs_AutoCollectMutation then break end
            if spawn:GetAttribute("RainbowSeed") ~= true and spawn:GetAttribute("GoldSeed") ~= true and spawn:GetAttribute("MegaSeed") ~= true then continue end
            local prompt = spawn:FindFirstChildWhichIsA("ProximityPrompt", true)
            if not prompt then continue end
            local pos = spawn:IsA("BasePart") and spawn.Position or (spawn:IsA("Model") and spawn:GetPivot().Position)
            if not pos then continue end
            slowFlyTo(pos)
            fireProximityPrompt(prompt)
            task.wait(MUTATION_COLLECT_WAIT)
        end
        collectingMutation = false
    end)
end

function findNearestDropPrompt()
    local hrp = getRoot()
    if not hrp then return nil end
    local best, bestDist
    for _, item in Services.Workspace:GetDescendants() do
        if not item:IsA("ProximityPrompt") then continue end
        local action = (item.ActionText or ""):lower()
        if not (action:find("pick") or action:find("collect")) then continue end
        local parent = item.Parent
        if not parent or (OwnerPlot and parent:IsDescendantOf(OwnerPlot)) then continue end
        local part = parent:IsA("BasePart") and parent or parent:FindFirstChildWhichIsA("BasePart", true)
        if not part then continue end
        local d = (part.Position - hrp.Position).Magnitude
        if not bestDist or d < bestDist then best, bestDist = { prompt = item, part = part }, d end
    end
    return best
end

function tryCollectDrops()
    if not genv.ftgs_AutoCollectDrops or collectingMutation or isCatchingPet or dropsBusy then return end
    local nearest = findNearestDropPrompt()
    if not nearest then return end
    dropsBusy = true
    task.spawn(function()
        movementBypass = true
        tpInstant(nearest.part.Position)
        fireProximityPrompt(nearest.prompt)
        task.wait(0.03)
        movementBypass = false
        dropsBusy = false
    end)
end

function hexColor(hex)
    if Color3.fromHex then
        local ok, c = xpcall(Color3.fromHex, noopErr, hex)
        if ok and typeof(c) == "Color3" then return c end
    end
    hex = tostring(hex):gsub("#", "")
    return Color3.fromRGB(tonumber(hex:sub(1, 2), 16) or 255, tonumber(hex:sub(3, 4), 16) or 255, tonumber(hex:sub(5, 6), 16) or 255)
end

function applyUITheme(name)
    selectedUITheme = name or selectedUITheme or "Black"
    local c = UI_THEMES[selectedUITheme] or UI_THEMES.Black
    local themeName = "NTMT_" .. selectedUITheme
    local fallback = ({ Black = "Dark", Pink = "Rose", Purple = "Violet", Blue = "Sky", Green = "Plant", Yellow = "Amber" })[selectedUITheme] or "Dark"
    if type(WindUI.AddTheme) == "function" then
        xpcall(function()
            WindUI:AddTheme({
                Name = themeName,
                Accent = hexColor(c.accent),
                Background = hexColor(c.bg),
                Button = hexColor(c.btn),
                Text = hexColor(c.text),
                Toggle = hexColor(c.toggle),
                Slider = hexColor(c.toggle),
                Outline = hexColor(c.accent),
                Icon = hexColor(c.text),
                Placeholder = hexColor("#888888"),
                Dialog = hexColor(c.bg),
            })
        end, noopErr)
    end
    if type(WindUI.SetTheme) == "function" then
        local applied = false
        xpcall(function() WindUI:SetTheme(themeName) applied = true end, noopErr)
        if not applied then xpcall(function() WindUI:SetTheme(fallback) end, noopErr) end
    end
    saveConfig()
end

