local function safeNetCall(remote, ...)
    if not remote then return false end
    local args = { ... }
    if type(remote.Fire) == "function" then
        return select(1, xpcall(function() remote:Fire(table.unpack(args)) end, noopErr))
    end
    if type(remote.InvokeServer) == "function" then
        return select(1, xpcall(function() return remote:InvokeServer(table.unpack(args)) end, noopErr))
    end
    return false
end

local function safeFlagGet(flagObj)
    if not flagObj then return {} end
    if type(flagObj.Get) == "function" then
        local ok, val = xpcall(function() return flagObj:Get() end, noopErr)
        if ok and type(val) == "table" then return val end
    end
    return {}
end

local function universalHttpGet(url)
    if game and type(game.HttpGet) == "function" then
        local ok, body = xpcall(function() return game:HttpGet(url) end, noopErr)
        if ok and type(body) == "string" and #body > 0 then return body end
    end
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if type(req) == "function" then
        local ok, res = xpcall(function() return req({ Url = url, Method = "GET" }) end, noopErr)
        if ok and res and type(res.Body or res.body) == "string" and #(res.Body or res.body) > 0 then
            return res.Body or res.body
        end
    end
    return nil
end

local function httpPost(url, body)
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if type(req) ~= "function" then return false end
    return xpcall(function()
        req({ Url = url, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = body })
    end, noopErr)
end

local WindUI
local function loadWindUI()
    local function finishWithLib(lib)
        if type(lib) ~= "table" or type(lib.CreateWindow) ~= "function" then return false end
        WindUI = lib
        return true
    end

    if type(loadstring) ~= "function" and type(load) ~= "function" then
        hubWarn("loadstring missing — using built-in UI")
        return finishWithLib(createBuiltinWindUI())
    end

    local body, patchedOk

    if isfile and isfile(WINDUI_CACHE) and readfile then
        local cached = readfile(WINDUI_CACHE)
        if type(cached) == "string" and #cached > 1000 then
            body, patchedOk = patchWindUISource(cached)
            if patchedOk then
                print("[NTMT HUB] Using cached patched WindUI")
            elseif delfile then
                pcall(delfile, WINDUI_CACHE)
            end
        end
    end

    if not patchedOk then
        body = universalHttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua")
        if type(body) ~= "string" or #body < 1000 then
            hubWarn("WindUI download failed — using built-in UI")
            return finishWithLib(createBuiltinWindUI())
        end
        body, patchedOk = patchWindUISource(body)
        if not patchedOk then
            hubWarn("WindUI patch failed — using built-in UI")
            return finishWithLib(createBuiltinWindUI())
        end
        if writefile then
            pcall(function()
                if makefolder then makefolder("ntmthub") end
                writefile(WINDUI_CACHE, body)
            end)
        end
    end

    cleanupBrokenGetIcons()

    local chunk, compileErr = compileWindUIChunk(body)
    if type(chunk) ~= "function" then
        hubWarn("WindUI compile failed — using built-in UI:", tostring(compileErr))
        return finishWithLib(createBuiltinWindUI())
    end
    local ok, lib = xpcall(chunk, function(err)
        if debug and debug.traceback then return debug.traceback(tostring(err), 2) end
        return tostring(err)
    end)
    if not ok or type(lib) ~= "table" or type(lib.CreateWindow) ~= "function" then
        hubWarn("WindUI runtime failed — using built-in UI:", tostring(lib))
        if delfile and isfile and isfile(WINDUI_CACHE) then pcall(delfile, WINDUI_CACHE) end
        return finishWithLib(createBuiltinWindUI())
    end
    WindUI = lib
    print("[NTMT HUB] WindUI loaded OK")
    return true
end

