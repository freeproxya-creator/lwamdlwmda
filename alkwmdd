function findGearTool(attrName, priority)
    local found = {}
    local function scan(c)
        if not c then return end
        for _, item in c:GetChildren() do
            if item:IsA("Tool") then local n = item:GetAttribute(attrName) if n then found[n] = item end end
        end
    end
    scan(LocalPlayer.Character)
    scan(LocalPlayer:FindFirstChild("Backpack"))
    for _, name in priority do if found[name] then return found[name], name end end
    return nil, nil
end

function findSeedToolByName(seedName)
    local function scan(c)
        if not c then return end
        for _, item in c:GetChildren() do
            if item:IsA("Tool") then
                local attr = item:GetAttribute("SeedTool")
                if attr and seedNamesMatch(attr, seedName) then return item, attr end
            end
        end
    end
    return scan(LocalPlayer.Character) or scan(LocalPlayer:FindFirstChild("Backpack"))
end

function pickNextPlantSeed()
