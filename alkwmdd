function tryShovel()
    if not genv.ftgs_AutoShovel or shovelBusy or not setHasAny(selectedShovelSeeds) then return end
    if os.clock() - lastShovel < COOLDOWN.Shovel then return end
    if not isNearPlotForActions() then return end
    refreshOwnerPlot()
    safeNetCall(Net.Garden and Net.Garden.RequestGardens)
    local list = {}
    for plantId, pd in pairs(trackedPlants) do
        local seed = getPlantSeedName(pd)
        if seedInSet(selectedShovelSeeds, seed) then
            list[#list + 1] = { plantId = plantId, mutation = pd.Mutation or "Normal", seedName = seed }
        end
    end
    if #list == 0 then
        local pf = OwnerPlot and OwnerPlot:FindFirstChild("Plants")
        if pf then
            for _, plant in pf:GetChildren() do
                local seed = plant:GetAttribute("SeedName") or plant:GetAttribute("PlantName")
                if seedInSet(selectedShovelSeeds, seed) then
                    list[#list + 1] = { plantId = plant:GetAttribute("PlantId"), mutation = plant:GetAttribute("Mutation") or "Normal", seedName = seed }
                end
            end
        end
    end
    if #list == 0 then return end
    table.sort(list, function(a, b)
        local ma = a.mutation == "Rainbow" and 3 or (a.mutation == "Gold" and 2 or 1)
        local mb = b.mutation == "Rainbow" and 3 or (b.mutation == "Gold" and 2 or 1)
        if ma ~= mb then return ma < mb end
        return getRarityRank(getSeedRarity(a.seedName)) > getRarityRank(getSeedRarity(b.seedName))
    end)
    local shovel, shovelName = findGearTool("Shovel", { "Advanced Shovel", "Common Shovel" })
    if not shovel then return end
    lastShovel = os.clock()
    shovelBusy = true
    task.spawn(function()
        equipTool(shovel)
        task.wait(0.2)
        shovel, shovelName = findGearTool("Shovel", { "Advanced Shovel", "Common Shovel" })
        if not shovel then shovelBusy = false return end
        local removed = 0
        for _, target in list do
            if removed >= SHOVEL_BATCH then break end
            if not target.plantId then continue end
            safeNetCall(Net.Shovel and Net.Shovel.UseShovel, target.plantId, "", shovelName, shovel)
            if type(shovel.Activate) == "function" then xpcall(function() shovel:Activate() end, noopErr) end
            removed += 1
            task.wait(COOLDOWN.Shovel)
        end
        shovelBusy = false
    end)
end

