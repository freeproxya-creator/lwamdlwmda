function tryExpand()
    if not genv.ftgs_AutoExpand then return end
    if os.clock() - lastExpand < COOLDOWN.Expand then return end
    local owned = (PlayerReplica and PlayerReplica.Data and PlayerReplica.Data.OwnedExpansions) or 1
    local nextInfo = ExpansionPrices[owned + 1]
    if not nextInfo then return end
    local price = (safeFlagGet(GardenFlags and GardenFlags.ExpansionPriceOverrides))[tostring(owned + 1)] or nextInfo.Price
    if getSheckles() < price then return end
    lastExpand = os.clock()
    safeNetCall(Net.Actions and Net.Actions.ExpandGarden)
end

