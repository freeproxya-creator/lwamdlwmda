function buildPriorityList(selected, fallbackList)
    local out, seen = {}, {}
    for name in selected do
        if not seen[name] then out[#out + 1], seen[name] = name, true end
    end
    table.sort(out)
    if #out > 0 then return out end
    return fallbackList
end

