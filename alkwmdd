function holdGardenStill(duration)
    refreshOwnerPlot()
    if not savedPlotCenter then return end
    local cf = CFrame.new(savedPlotCenter + Vector3.new(0, 3, 0))
    gardenActionLock = true
    movementBypass = true
    local deadline = os.clock() + (duration or 0.5)
    while os.clock() < deadline do
        local hrp = getRoot()
        local hum = getHumanoid()
        if hrp then
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            hrp.CFrame = cf
        end
        if hum then hum.PlatformStand = true end
        task.wait(0.04)
    end
    local hum = getHumanoid()
    if hum then hum.PlatformStand = false end
    gardenActionLock = false
end

