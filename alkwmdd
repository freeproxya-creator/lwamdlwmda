    extra = extra or 0
    local hx = (savedPlotSize and savedPlotSize.X or 44) / 2 + extra
    local hz = (savedPlotSize and savedPlotSize.Z or 44) / 2 + extra
    return math.abs(hrp.Position.X - savedPlotCenter.X) <= hx
        and math.abs(hrp.Position.Z - savedPlotCenter.Z) <= hz
end

