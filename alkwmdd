function cachePlantPositions(plot)
    table.clear(savedPlantPositions)
    if not plot then return end
    local visual = plot:FindFirstChild("Visual")
    if not visual then return end
    for _, col in visual:GetChildren() do
        if col.Name:match("^PlantAreaColumn") then
            for _, part in col:GetChildren() do
                if part:IsA("BasePart") then savedPlantPositions[#savedPlantPositions + 1] = part.Position end
            end
        end
    end
end

function refreshPlantAreas()
    table.clear(plantAreas)
    for _, pos in savedPlantPositions do plantAreas[#plantAreas + 1] = pos end
    if #plantAreas == 0 and savedPlotCenter then
        local step, hx, hz = 4, savedPlotSize.X / 2 - 2, savedPlotSize.Z / 2 - 2
        for x = -hx, hx, step do
            for z = -hz, hz, step do
                plantAreas[#plantAreas + 1] = Vector3.new(savedPlotCenter.X + x, savedPlotCenter.Y, savedPlotCenter.Z + z)
            end
        end
    end
end

function refreshOwnerPlot()
    if OwnerPlot and OwnerPlot.Parent then return OwnerPlot end
    if not Gardens then return nil end
    for _, plot in Gardens:GetChildren() do
        if plot:GetAttribute("Owner") == LocalPlayer.Name or plot:GetAttribute("OwnerUserId") == LocalPlayer.UserId then
            OwnerPlot = plot
            PlayerPlot = plot
            local psr = plot:FindFirstChild("PlotSizeReference")
            if psr and psr:IsA("BasePart") then
                savedPlotCenter, savedPlotSize = psr.Position, psr.Size
            else
                savedPlotCenter = plot:GetPivot().Position
            end
            cachePlantPositions(plot)
            refreshPlantAreas()
            return plot
        end
    end
    return nil
end

