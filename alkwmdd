function slowFlyTo(targetPos)
    if not targetPos then return false end
    movementBypass = true
    local deadline = os.clock() + 90
    while os.clock() < deadline do
        local hrp = getRoot()
        if not hrp then break end
        local goal = targetPos + Vector3.new(0, 2.5, 0)
        local dist = (hrp.Position - goal).Magnitude
        if dist <= 5 then
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            hrp.CFrame = CFrame.new(goal)
            movementBypass = false
            return true
        end
        local step = math.max(dist * SLOW_FLY_RATIO, 0.75)
        local dir = (goal - hrp.Position).Unit
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        hrp.CFrame = CFrame.new(hrp.Position + dir * math.min(step, dist))
        task.wait(0.07)
    end
    movementBypass = false
    return false
end

