function countSeedOwned(name)
    local n = 0
    local function scan(c)
        if not c then return end
        for _, item in c:GetChildren() do
            if item:IsA("Tool") and seedNamesMatch(item:GetAttribute("SeedTool"), name) then n += 1 end
        end
    end
    local pf = OwnerPlot and OwnerPlot:FindFirstChild("Plants")
    if pf then
        for _, plant in pf:GetChildren() do
            local sn = plant:GetAttribute("SeedName") or plant:GetAttribute("PlantName")
            if seedNamesMatch(sn, name) then n += 1 end
        end
    end
    scan(LocalPlayer.Character)
    scan(LocalPlayer:FindFirstChild("Backpack"))
