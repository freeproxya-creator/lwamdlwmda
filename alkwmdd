function hookGardenRemotes()
    local function hook(name, fn)
        local r = Net.Garden and Net.Garden[name]
        if r and r.OnClientEvent then xpcall(function() r.OnClientEvent:Connect(fn) end, noopErr) end
    end
    hook("PlantAdded", function(uid, pid, data) if uid == myUserId then trackedPlants[pid] = data end end)
    hook("PlantRemoved", function(uid, pid) if uid == myUserId then trackedPlants[pid] = nil end end)
    hook("FruitAdded", function(uid, pid, fruitId, data)
        if uid ~= myUserId then return end
        if not trackedPlants[pid] then trackedPlants[pid] = { Fruits = {} } end
        if not trackedPlants[pid].Fruits then trackedPlants[pid].Fruits = {} end
        trackedPlants[pid].Fruits[fruitId] = data
    end)
    hook("FruitRemoved", function(uid, pid, fruitId)
        if uid ~= myUserId then return end
        local p = trackedPlants[pid]
        if p and p.Fruits then p.Fruits[fruitId] = nil end
    end)
    local sync = Net.Garden and Net.Garden.SyncAllGardens
    if sync and sync.OnClientEvent then
        xpcall(function()
            sync.OnClientEvent:Connect(function(data)
                for uid, info in pairs(data) do
                    if (tonumber(uid) or uid) == myUserId and info.Plants then trackedPlants = info.Plants end
                end
            end)
        end, noopErr)
    end
end
hookGardenRemotes()

function tpInstant(pos)
    local hrp = getRoot()
    if not hrp or not pos then return false end
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
    return true
end

function getGearStandPos(placePos)
    return placePos + Vector3.new(0, 3, 0)
end

function flySteps(from, to)
    local dist = (to - from).Magnitude
    if dist <= 6 then tpInstant(to - Vector3.new(0, 3, 0)) return end
    local steps = math.max(2, math.ceil(dist / FLY_STEP))
    for i = 1, steps do
        local hrp = getRoot()
        if not hrp then return end
        local hum = getHumanoid()
        if hum then hum.Sit = false end
        local nextPos = from:Lerp(to, i / steps)
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        hrp.CFrame = CFrame.new(nextPos)
        task.wait(0.08)
    end
end

function segmentedFlyTo(targetPos)
    local hrp = getRoot()
    if not hrp or not targetPos then return false end
    local goal = targetPos + Vector3.new(0, 3, 0)
    local start = hrp.Position
    if (goal - start).Magnitude <= 6 then return tpInstant(targetPos) end
    for _, t in { 0.3, 0.6, 0.9, 1.0 } do
        hrp = getRoot()
        if not hrp then return false end
        flySteps(hrp.Position, start:Lerp(goal, t))
        if t < 1 then task.wait(SEGMENT_PAUSE) end
    end
    return true
end

