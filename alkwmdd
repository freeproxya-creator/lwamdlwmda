    if PlayerReplica and PlayerReplica.Data and PlayerReplica.Data.PurchasedThisRestock then
        bought = (PlayerReplica.Data.PurchasedThisRestock.Seeds or {})[name] or 0
    end
    return math.max(maxStock - bought, 0)
end

function getGearStock(name)
